# Local overrides for running the scripts by hand (copy to .env; .env is gitignored).
# NEVER put real values in a tracked file - .env.example holds placeholders only.
# In CI these come from GitHub variables/secrets instead (docs/github-secrets-setup.md).

# --- Loop inputs (identifiers) ---
MODE=review                    # review | auto | chat
NAMESPACE=                     # empty = cluster-wide
TARGET=                        # optional deployment/pod to scope
MAX_ITERATIONS=3

# --- Azure / AKS (identifiers) ---
AKS_RESOURCE_GROUP=<your aks resource group>
AKS_CLUSTER_NAME=<your aks cluster name>

# --- Slack (credential - real value only in .env, never committed) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../XXXX
