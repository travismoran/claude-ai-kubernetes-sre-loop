{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sre-loop/schemas/remediation-plan.schema.json",
  "title": "RemediationPlan",
  "type": "object",
  "required": ["target", "root_cause", "actions", "escalated", "confidence"],
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "object",
      "required": ["kind", "namespace", "name"],
      "properties": {
        "kind": {"type": "string"},
        "namespace": {"type": "string"},
        "name": {"type": "string"}
      }
    },
    "root_cause": {"type": "string"},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "command", "destructive", "applied"],
        "additionalProperties": true,
        "properties": {
          "type": {"type": "string", "enum": ["restart", "scale", "delete-pod", "cordon", "annotate", "none"]},
          "command": {"type": "string"},
          "destructive": {"type": "boolean"},
          "applied": {"type": "boolean"},
          "result": {"type": "string"},
          "rollback": {"type": "string"}
        }
      }
    },
    "escalated": {"type": "boolean"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
